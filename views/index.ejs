          class="bg-gradient-to-r from-blue-600 to-teal-500 bg-clip-text text-transparent">MediBook</span></h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="feature-card p-8 rounded-3xl fade-up delay-1">
          <div class="text-5xl mb-4">🩺</div>
          <h3 class="text-2xl font-bold mb-3 text-slate-800">Verified Doctors</h3>
          <p class="text-slate-600">All professionals are credential-checked, with authentic profiles and patient trust.
          </p>
        </div>
        <div class="feature-card p-8 rounded-3xl fade-up delay-2">
          <div class="text-5xl mb-4">📅</div>
          <h3 class="text-2xl font-bold mb-3 text-slate-800">Easy Booking</h3>
          <p class="text-slate-600">Appointments in seconds, 24/7 availability — no phone tag, no waiting.</p>
        </div>
        <div class="feature-card p-8 rounded-3xl fade-up delay-3">
          <div class="text-5xl mb-4">⭐</div>
          <h3 class="text-2xl font-bold mb-3 text-slate-800">Patient Reviews</h3>
          <p class="text-slate-600">Real feedback and ratings help you choose the best doctor with confidence.</p>
        </div>
      </div>
    </div>
  </section>

