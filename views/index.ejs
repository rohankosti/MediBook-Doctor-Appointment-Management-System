<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MediBook · heal smart</title>
  <!-- Tailwind (light usage) & enhanced custom styling -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Font: Plus Jakarta Sans (modern, friendly) -->
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
    <!-- Font Awesome Kit -->
    <script src="https://kit.fontawesome.com/4cdd077a78.js" crossorigin="anonymous"></script>
  <style>
    /* ---------- RESET & GLOBAL THEME ---------- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
      background: radial-gradient(circle at 0% 30%, rgba(15, 118, 252, 0.12), transparent 50%),
        radial-gradient(circle at 100% 70%, rgba(20, 184, 166, 0.12), transparent 55%),
        linear-gradient(145deg, #f6faff 0%, #f1f5fe 50%, #f0fdfc 100%);
      min-height: 100vh;
      color: #13294e;
      scroll-behavior: smooth;
    }

    /* ---------- CUSTOM VARIABLES (vibrant theme) ---------- */
    :root {
      --primary: #2563eb;
      --primary-deep: #1d4ed8;
      --secondary: #14b8a6;
      --accent: #8b5cf6;
      --soft-blue: #dbeafe;
      --teal-mist: #ccfbf1;
      --glass-bg: rgba(255, 255, 255, 0.68);
      --glass-border: rgba(255, 255, 255, 0.5);
      --shadow-elegant: 0 20px 40px -12px rgba(0, 35, 80, 0.25);
      --shadow-hover: 0 30px 50px -18px rgba(37, 99, 235, 0.4);
    }

    /* ---------- GLASS NAVBAR (luxury blur) ---------- */
    nav {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      border-bottom: 1px solid rgba(255, 255, 255, 0.7);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    }

    /* ---------- LOGO: ADVANCED ANIMATION (float + glow + soft tilt) ---------- */
    .logo-icon {
      display: inline-block;
      animation: floatAndGlow 4s ease-in-out infinite;
      filter: drop-shadow(0 4px 6px rgba(37, 99, 235, 0.2));
    }

    @keyframes floatAndGlow {
      0% {
        transform: translateY(0px) rotate(0deg);
        text-shadow: 0 0 0 rgba(37, 99, 235, 0.2);
      }

      30% {
        transform: translateY(-5px) rotate(1.5deg);
        text-shadow: 0 10px 18px rgba(37, 99, 235, 0.4);
      }

      60% {
        transform: translateY(2px) rotate(-0.5deg);
        text-shadow: 0 4px 10px rgba(20, 184, 166, 0.3);
      }

      100% {
        transform: translateY(0px) rotate(0deg);
        text-shadow: 0 0 0 rgba(37, 99, 235, 0.2);
      }
    }

    .logo-text {
      background: linear-gradient(115deg, #2563eb, #14b8a6, #8b5cf6);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      background-size: 200% auto;
      animation: gradientShift 6s ease infinite;
    }

    @keyframes gradientShift {
      0% {
        background-position: 0% center;
      }

      50% {
        background-position: 100% center;
      }

      100% {
        background-position: 0% center;
      }
    }

    /* ---------- NAV LINK UNDERLINE (elegant) ---------- */
    .nav-link {
      position: relative;
      font-weight: 550;
      transition: color 0.2s ease;
    }

    .nav-link::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -4px;
      width: 0%;
      height: 2.5px;
      background: linear-gradient(90deg, var(--primary), var(--secondary), var(--accent));
      border-radius: 4px;
      transition: width 0.3s cubic-bezier(0.2, 0.9, 0.3, 1.1);
    }

    .nav-link:hover {
      color: var(--primary);
    }

    .nav-link:hover::after {
      width: 100%;
    }

    /* ---------- GLOBAL BUTTON STYLE (3D depth + shine) ---------- */
    .btn-primary {
      background: linear-gradient(135deg, #2563eb, #1e40af, #312e81);
      background-size: 200% 200%;
      border: none;
      color: white;
      font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: 0 10px 20px -8px rgba(37, 99, 235, 0.4);
      position: relative;
      z-index: 1;
      overflow: hidden;
    }

    .btn-primary::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: left 0.5s ease;
      z-index: -1;
    }

    .btn-primary:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 25px 35px -12px #1e3a8a;
    }

    .btn-primary:hover::before {
      left: 100%;
    }

    .btn-outline {
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(37, 99, 235, 0.2);
      color: #1e293b;
      font-weight: 600;
      transition: 0.25s;
    }

    .btn-outline:hover {
      background: white;
      border-color: #2563eb;
      box-shadow: 0 12px 24px -12px #2563eb30;
      transform: translateY(-2px);
    }

    /* ---------- CARD STYLES (glass, depth, hover) ---------- */
    .glass-card {
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.9);
      box-shadow: var(--shadow-elegant);
      transition: all 0.25s ease;
    }

    .glass-card:hover {
      transform: translateY(-6px);
      background: rgba(255, 255, 255, 0.9);
      border-color: white;
      box-shadow: var(--shadow-hover);
    }

    .feature-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(6px);
      border: 1px solid rgba(165, 188, 255, 0.2);
      box-shadow: 0 10px 25px -12px #1e293b30;
      transition: 0.2s;
    }

    .feature-card:hover {
      background: white;
      border-color: var(--secondary);
      box-shadow: 0 25px 30px -15px #14b8a640;
    }

    .doctor-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(20, 184, 166, 0.15);
      transition: 0.3s cubic-bezier(0.15, 0.75, 0.4, 1);
    }

    .doctor-card:hover {
      background: white;
      transform: scale(1.02) translateY(-6px);
      box-shadow: 0 25px 35px -15px #2563eb70;
    }

    /* animated stat numbers (subtle pulse) */
    .stat-number {
      animation: statPulse 3s infinite;
    }

    @keyframes statPulse {
      0% {
        text-shadow: 0 0 0px #2563eb40;
      }

      50% {
        text-shadow: 0 0 8px #2563eb80, 0 0 15px #14b8a660;
      }

      100% {
        text-shadow: 0 0 0px #2563eb40;
      }
    }

    /* floating blobs (background interest) */
    .blob {
      position: absolute;
      border-radius: 70% 30% 60% 40% / 50% 60% 40% 50%;
      filter: blur(60px);
      opacity: 0.5;
      z-index: 0;
      animation: morph 15s linear infinite alternate;
    }

    @keyframes morph {
      0% {
        border-radius: 70% 30% 60% 40% / 50% 60% 40% 50%;
        transform: translate(0, 0) scale(1);
      }

      100% {
        border-radius: 40% 60% 30% 70% / 60% 30% 70% 40%;
        transform: translate(20px, -20px) scale(1.1);
      }
    }

    /* fade-in on scroll (simple css) */
    .fade-up {
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.8s ease forwards;
    }

    @keyframes fadeUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* delay classes */
    .delay-1 {
      animation-delay: 0.1s;
    }

    .delay-2 {
      animation-delay: 0.2s;
    }

    .delay-3 {
      animation-delay: 0.3s;
    }

    /* footer contact hover effect */
    .contact-item {
      transition: transform 0.2s ease, color 0.2s;
    }

    .contact-item:hover {
      transform: translateX(6px);
      color: white;
    }
  </style>
</head>

