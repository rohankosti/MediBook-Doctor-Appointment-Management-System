<%- include('partial/header') %>

  <!-- Hero Section (enhanced) -->
  <section class="relative py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 text-center relative z-10">
      <!-- heading with shimmer -->
      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-6 fade-up">
        Smart Healthcare with<br>
        <span
          class="bg-gradient-to-r from-blue-700 via-teal-600 to-purple-600 bg-clip-text text-transparent bg-[size:200%] animate-gradientShift">
          MediBook
        </span>
      </h1>
      <p class="text-lg md:text-xl text-slate-700/90 max-w-2xl mx-auto mb-10 fade-up delay-1">
        Find trusted doctors, check reviews, and book appointments online<br class="hidden sm:block"> in seconds — no
        queues, no hassle.
      </p>

      <!-- CTA buttons with custom classes -->
      <div class="flex justify-center gap-5 mb-20 fade-up delay-2">
        <a href="/doctors" class="btn-primary px-8 py-4 rounded-2xl text-lg shadow-xl">Find Doctors</a>
        <a href="/register"
          class="btn-outline px-8 py-4 rounded-2xl text-lg backdrop-blur-sm bg-white/50 border border-slate-200/80">Create
          Account</a>
      </div>

      <!-- Stats cards (glass + hover) -->
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto fade-up delay-3">
        <div class="glass-card p-8 rounded-2xl text-center">
          <h3 class="stat-number text-4xl font-black text-blue-700">500+</h3>
          <p class="text-slate-700 font-medium">Verified Doctors</p>
        </div>
        <div class="glass-card p-8 rounded-2xl text-center">
          <h3 class="stat-number text-4xl font-black text-teal-600">10K+</h3>
          <p class="text-slate-700 font-medium">Happy Patients</p>
        </div>
        <div class="glass-card p-8 rounded-2xl text-center">
          <h3 class="stat-number text-4xl font-black text-indigo-600">24/7</h3>
          <p class="text-slate-700 font-medium">Online Booking</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features (modern, with unique card style) -->
