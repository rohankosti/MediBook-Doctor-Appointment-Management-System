<%- include('partial/header') %>
<section class="py-24">
<div class="max-w-4xl mx-auto px-6">

<h1 class="text-5xl font-bold text-center mb-12">
Contact Us
</h1>

<form class="glass-card p-10 rounded-3xl space-y-6">

<div>
<label class="block mb-2 font-semibold">Name</label>
<input type="text"
class="w-full border rounded-xl p-3 outline-none">
</div>

<div>
<label class="block mb-2 font-semibold">Email</label>
<input type="email"
class="w-full border rounded-xl p-3 outline-none">
</div>

<div>
<label class="block mb-2 font-semibold">Message</label>
<textarea
class="w-full border rounded-xl p-3 outline-none"
rows="4"></textarea>
</div>

<button class="btn-primary px-8 py-3 rounded-xl">
Send Message
</button>

</form>

</div>
</section><%- include('partial/footer') %>