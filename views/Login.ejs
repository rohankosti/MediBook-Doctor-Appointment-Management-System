<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MediBook · Login</title>

<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

body{
font-family:'Plus Jakarta Sans',sans-serif;
background: radial-gradient(circle at 0% 30%, rgba(15,118,252,0.12), transparent 50%),
radial-gradient(circle at 100% 70%, rgba(20,184,166,0.12), transparent 55%),
linear-gradient(145deg,#f6faff 0%,#f1f5fe 50%,#f0fdfc 100%);
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
}

.logo-text{
background:linear-gradient(115deg,#2563eb,#14b8a6,#8b5cf6);
-webkit-background-clip:text;
color:transparent;
}

.glass-card{
background:rgba(255,255,255,0.75);
backdrop-filter:blur(12px);
border:1px solid rgba(255,255,255,0.9);
box-shadow:0 20px 40px -12px rgba(0,35,80,0.25);
}

.btn-primary{
background:linear-gradient(135deg,#2563eb,#1e40af,#312e81);
color:white;
font-weight:600;
transition:.3s;
}

.btn-primary:hover{
transform:translateY(-2px);
box-shadow:0 20px 30px -10px #1e3a8a;
}

.input-field{
border:1px solid #e2e8f0;
transition:.2s;
}

.input-field:focus{
border-color:#2563eb;
box-shadow:0 0 0 2px rgba(37,99,235,.15);
outline:none;
}

</style>
</head>

<body>

<div class="glass-card p-10 rounded-3xl w-full max-w-md">

<!-- Logo -->
<div class="text-center mb-8">
<h1 class="text-3xl font-bold logo-text">⚕ MediBook</h1>
<p class="text-slate-500 mt-2">Welcome back</p>
</div>

<form action="/login" method="POST" class="space-y-5">

<div>
<label class="text-sm font-medium text-slate-600">Email</label>
<input type="email" name="email" required
class="input-field w-full mt-2 px-4 py-3 rounded-xl">
</div>

<div>
<label class="text-sm font-medium text-slate-600">Password</label>
<input type="password" name="password" required
class="input-field w-full mt-2 px-4 py-3 rounded-xl">
</div>

<div class="flex justify-between items-center text-sm">
<label class="flex items-center gap-2">
<input type="checkbox">
Remember me
</label>

<a href="#" class="text-blue-600 hover:underline">
Forgot password?
</a>
</div>

<button class="btn-primary w-full py-3 rounded-xl">
Login
</button>

</form>

<p class="text-center text-sm text-slate-600 mt-6">
Don't have an account?
<a href="/register" class="text-blue-600 font-semibold hover:underline">
Create account
</a>
</p>

</div>

</body>
</html>